{
  "name": "gravity-claw",
  "version": "1.0.0",
  "description": "Gravity Claw - A personal AI agent",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "start": "npx tsx src/index.ts",
    "dev": "node --import tsx src/index.ts",
    "mc": "cd mission-control-react && npm run dev",
    "launch": "concurrently -n bot,mc -c blue,magenta \"npm start\" \"npm run mc\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@google/genai": "^1.43.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@supabase/supabase-js": "^2.98.0",
    "dotenv": "^16.4.5",
    "grammy": "^1.34.0",
    "openai": "^6.25.0",
    "puppeteer": "^24.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "concurrently": "^9.2.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^4.1.0"
  }
}